# Environment
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/ecommerce
DB_POOL_MIN=2
DB_POOL_MAX=10

# Auth
JWT_SECRET=dev-secret-change-in-production

# Logging
LOG_LEVEL=debug

# Payments
PAYMENT_PROVIDER=mock
# MercadoPago
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=
# Transbank WebPay
TBK_COMMERCE_CODE=
TBK_API_KEY=
TBK_ENV=integration

# Comma-separated provider webhook source IPs/CIDRs for production.
# Leave empty only in local development.
PAYMENT_WEBHOOK_IP_ALLOWLIST=

# AI Stylist
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=
# Provider: claude | deepseek
STYLIST_AI_PROVIDER=claude
