<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta name="csrf-token" content="<%= it.csrfToken %>">
  <title><%= it.title ?? 'Tienda' %> | <%= it.siteName ?? 'Maison \u00c9lite' %></title>
  <% if (it.metaDescription) { %>
  <meta name="description" content="<%= it.metaDescription %>">
  <% } %>
  <% if (it.metaImage) { %>
  <meta property="og:image" content="<%= it.metaImage %>">
  <% } %>
  <meta property="og:title" content="<%= it.title ?? 'Tienda' %>">
  <meta property="og:type" content="website">
  <% if (it.canonicalUrl) { %>
  <link rel="canonical" href="<%= process.env.BASE_URL ?? 'http://localhost:3000' %><%= it.canonicalUrl %>">
  <% } %>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500&family=Playfair+Display:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/static/css/main.css">
  <link rel="stylesheet" href="/static/css/stylist.css">
  <script src="/static/js/htmx.min.js"></script>
  <script src="/static/js/main.js"></script>
</head>
<body>
  <header>
    <nav>
      <a href="/" class="logo"><%= it.siteName ?? 'Maison \u00c9lite' %></a>
      <div class="nav-search">
        <form action="/search" method="GET" class="search-bar-nav" autocomplete="off">
          <input type="text" name="q" placeholder="Buscar productos..." class="search-input" id="nav-search" hx-get="/api/search/suggest" hx-trigger="keyup changed delay:300ms, search" hx-target="#search-suggestions">
          <button type="submit" class="btn btn-primary btn-sm">Buscar</button>
          <div id="search-suggestions" class="search-suggestions"></div>
        </form>
      </div>
      <div class="nav-links">
        <a href="/categories/ropa-de-mujer">Mujer</a>
        <a href="/categories/ropa-de-hombre">Hombre</a>
        <a href="/categories/accesorios">Accesorios</a>
        <a href="/categories/calzado">Calzado</a>
        <a href="/cart" id="cart-link">Carrito (<span id="cart-count"><%= it.cartCount ?? 0 %></span>)</a>
        <% if (it.customer) { %>
        <a href="/cuenta">Mi cuenta</a>
        <form action="/cuenta/logout" method="post" style="display:inline">
          <input type="hidden" name="csrfToken" value="<%= it.csrfToken %>">
          <button type="submit" class="btn btn-sm" style="background:none;border:none;color:inherit;cursor:pointer;font-size:inherit;text-decoration:underline">Cerrar sesion</button>
        </form>
        <% } else { %>
        <a href="/cuenta/login">Ingresar</a>
        <% } %>
      </div>
    </nav>
  </header>
  <main>
    <%~ it.body %>
  </main>
  <!-- Stylist FAB -->
  <button id="stylist-fab" aria-label="Abrir estilista de moda">
    <span class="fab-icon">✨</span>
    <span>Estilista IA</span>
  </button>

  <!-- Stylist Modal -->
  <div id="stylist-modal" role="dialog" aria-label="Asistente de moda">
    <div class="stylist-header">
      <div>
        <div class="stylist-header-title">✨ Tu Estilista Personal</div>
        <div class="stylist-header-sub">Recomendaciones con IA · Productos reales</div>
      </div>
      <button class="stylist-close" id="stylist-close" aria-label="Cerrar">&times;</button>
    </div>
    <div class="stylist-messages" id="stylist-messages">
      <div class="stylist-welcome">
        <div class="welcome-icon">✨</div>
        <p><strong>¡Hola! Soy tu estilista personal.</strong></p>
        <p>Cuéntame tu objetivo o sube una foto y te armaré looks con productos de nuestra tienda.</p>
      </div>
    </div>
    <div class="stylist-quick-prompts">
      <button class="quick-prompt-btn" data-prompt="Quiero un look casual para el fin de semana, algo cómodo y moderno">Casual fin de semana</button>
      <button class="quick-prompt-btn" data-prompt="Necesito un traje formal para una entrevista de trabajo">Formal para trabajo</button>
      <button class="quick-prompt-btn" data-prompt="Busco un outfit para una boda, quiero verme elegante y estilizado">Look para boda</button>
      <button class="quick-prompt-btn" data-prompt="Quiero looks que me hagan ver más delgado y estilizado">Más estilizado</button>
    </div>
    <div class="stylist-input-area">
      <div class="stylist-tools">
        <button class="stylist-photo-btn" id="stylist-photo-btn" type="button">📷 Subir foto</button>
        <input type="file" id="stylist-photo-input" accept="image/*" style="display:none" capture="user">
        <div class="stylist-photo-preview" id="stylist-photo-preview" style="display:none">
          📷 <span id="stylist-photo-name"></span>
          <button class="stylist-photo-remove" id="stylist-photo-remove" type="button">&times;</button>
        </div>
        <button class="stylist-reset-btn" id="stylist-reset" type="button">Reiniciar</button>
      </div>
      <div class="stylist-input-row">
        <textarea
          class="stylist-input"
          id="stylist-input"
          placeholder="Ej: Quiero un look elegante para una cena, presupuesto $50.000..."
          rows="1"
          maxlength="1000"
        ></textarea>
        <button class="stylist-send" id="stylist-send" type="button" aria-label="Enviar">➤</button>
      </div>
    </div>
  </div>
  <script src="/static/js/stylist.js"></script>

  <footer>
    <div class="footer-content">
      <div class="footer-section">
        <h4><%= it.siteName ?? 'Maison \u00c9lite' %></h4>
        <p>Tu tienda online de confianza.</p>
      </div>
      <div class="footer-section">
        <h4>Enlaces</h4>
        <ul>
          <li><a href="/search">Productos</a></li>
          <li><a href="/cuenta">Mi cuenta</a></li>
          <li><a href="/cuenta/pedidos">Mis pedidos</a></li>
        </ul>
      </div>
      <div class="footer-section">
        <h4>Legal</h4>
        <ul>
          <li><a href="/politicas/devoluciones">Política de devoluciones</a></li>
          <li><a href="/politicas/privacidad">Política de privacidad</a></li>
          <li><a href="/politicas/envio">Envíos y entregas</a></li>
        </ul>
      </div>
    </div>
    <p class="footer-copy">&copy; <%= new Date().getFullYear() %> <%= it.siteName ?? 'Maison \u00c9lite' %>. Todos los derechos reservados.</p>
  </footer>
</body>
</html>
